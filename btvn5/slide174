#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>
#include <sys/socket.h>
#include <pthread.h>

#define MAX_CLIENTS 50
#define PORT 9000
#define BUFFER_SIZE 2048

typedef struct {
    int socket;
    char name[50];
    int is_registered;
} ClientInfo;

ClientInfo clients[MAX_CLIENTS];
pthread_mutex_t clients_mutex = PTHREAD_MUTEX_INITIALIZER;

void broadcast(const char* message, int sender_socket) {
    pthread_mutex_lock(&clients_mutex);
    for (int i = 0; i < MAX_CLIENTS; i++) {
        if (clients[i].socket != -1 && clients[i].is_registered && clients[i].socket != sender_socket) {
            send(clients[i].socket, message, strlen(message), 0);
        }
    }
    pthread_mutex_unlock(&clients_mutex);
}

void* client_handler(void* arg) {
    int index = *(int*)arg;
    free(arg);
    int sock = clients[index].socket;
    char buffer[BUFFER_SIZE];

    while (1) {
        memset(buffer, 0, BUFFER_SIZE);
        int n = recv(sock, buffer, sizeof(buffer) - 1, 0);
        if (n <= 0) goto cleanup;

        buffer[strcspn(buffer, "\r\n")] = 0;

        char *pos = strstr(buffer, "client_id:");
        if (pos != NULL) {
            char *name_ptr = pos + 10;
            while (*name_ptr == ' ') name_ptr++;

            if (strlen(name_ptr) > 0) {
                pthread_mutex_lock(&clients_mutex);
                strncpy(clients[index].name, name_ptr, 49);
                clients[index].is_registered = 1;
                pthread_mutex_unlock(&clients_mutex);
                break;
            }
        }
    }

    while (1) {
        memset(buffer, 0, BUFFER_SIZE);
        int n = recv(sock, buffer, sizeof(buffer) - 1, 0);
        if (n <= 0) break;

        buffer[strcspn(buffer, "\r\n")] = 0;
        if (strlen(buffer) == 0) continue;

        char out_msg[BUFFER_SIZE + 100];
        sprintf(out_msg, "%s: %s\n", clients[index].name, buffer);
        broadcast(out_msg, sock);
    }

cleanup:
    pthread_mutex_lock(&clients_mutex);
    close(sock);
    clients[index].socket = -1;
    clients[index].is_registered = 0;
    pthread_mutex_unlock(&clients_mutex);
    return NULL;
}

int main() {
    int server_sock = socket(AF_INET, SOCK_STREAM, 0);
    int opt = 1;
    setsockopt(server_sock, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));

    struct sockaddr_in addr = {AF_INET, htons(PORT), INADDR_ANY};
    bind(server_sock, (struct sockaddr*)&addr, sizeof(addr));
    listen(server_sock, 10);

    for (int i = 0; i < MAX_CLIENTS; i++) clients[i].socket = -1;

    while (1) {
        int new_sock = accept(server_sock, NULL, NULL);
        pthread_mutex_lock(&clients_mutex);
        for (int i = 0; i < MAX_CLIENTS; i++) {
            if (clients[i].socket == -1) {
                clients[i].socket = new_sock;
                clients[i].is_registered = 0;
                int *arg = malloc(sizeof(int));
                *arg = i;
                pthread_t tid;
                pthread_create(&tid, NULL, client_handler, arg);
                pthread_detach(tid);
                break;
            }
        }
        pthread_mutex_unlock(&clients_mutex);
    }
    return 0;
}
