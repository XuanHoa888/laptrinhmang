#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <winsock2.h>

#pragma comment(lib, "ws2_32.lib")

int main(int argc, char *argv[]) {
    if (argc != 4) {
        printf("Usage: udp_chat port_s ip_d port_d\n");
        return 1;
    }

    int port_s = atoi(argv[1]);
    char *ip_d = argv[2];
    int port_d = atoi(argv[3]);

    // Khoi tao Winsock
    WSADATA wsa;
    WSAStartup(MAKEWORD(2, 2), &wsa);

    SOCKET sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);

    struct sockaddr_in local;
    local.sin_family = AF_INET;
    local.sin_addr.s_addr = INADDR_ANY;
    local.sin_port = htons(port_s);

    bind(sock, (struct sockaddr*)&local, sizeof(local));

    // dia chi dich
    struct sockaddr_in dest;
    dest.sin_family = AF_INET;
    dest.sin_addr.s_addr = inet_addr(ip_d);
    dest.sin_port = htons(port_d);

    char buf[1024];

    printf("UDP Chat started...\n");

    while (1) {
        fd_set readfds;
        FD_ZERO(&readfds);

        FD_SET(sock, &readfds);
        FD_SET(0, &readfds);

        select(0, &readfds, NULL, NULL, NULL);

        // Nhap tu ban phim -> send
        if (FD_ISSET(0, &readfds)) {
            fgets(buf, sizeof(buf), stdin);
            sendto(sock, buf, strlen(buf), 0,
                   (struct sockaddr*)&dest, sizeof(dest));
        }

        // Nhan du lieu -> print
        if (FD_ISSET(sock, &readfds)) {
            struct sockaddr_in sender;
            int sender_len = sizeof(sender);

            int len = recvfrom(sock, buf, sizeof(buf)-1, 0,
                               (struct sockaddr*)&sender, &sender_len);
            if (len > 0) {
                buf[len] = 0;
                printf("\n[%s:%d]: %s",
                       inet_ntoa(sender.sin_addr),
                       ntohs(sender.sin_port),
                       buf);
            }
        }
    }

    closesocket(sock);
    WSACleanup();
    return 0;
}
