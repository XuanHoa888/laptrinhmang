#include <stdio.h>
#include <winsock2.h>
#include <string.h>

#pragma comment(lib, "ws2_32.lib")

#define PORT 9000
#define MAX_CLIENTS 10
#define BUFFER_SIZE 2048

typedef struct {
    SOCKET socket;
    int logged_in;
    char cmd_buffer[BUFFER_SIZE];
} Client;

int check_login(char *user, char *pass) {
    FILE *f = fopen("accounts.txt", "r");
    if (f == NULL) return 0;

    char f_user[50], f_pass[50];
    while (fscanf(f, "%s %s", f_user, f_pass) != EOF) {
        if (strcmp(user, f_user) == 0 && strcmp(pass, f_pass) == 0) {
            fclose(f);
            return 1;
        }
    }
    fclose(f);
    return 0;
}

void send_command_result(SOCKET s) {
    FILE *f = fopen("out.txt", "r");
    if (f == NULL) return;

    char line[BUFFER_SIZE];
    while (fgets(line, sizeof(line), f)) {
        send(s, line, strlen(line), 0);
    }
    fclose(f);
}

int main() {
    WSADATA wsa;
    SOCKET master_socket, new_socket;
    struct sockaddr_in server;
    fd_set readfds;
    Client clients[MAX_CLIENTS] = {0};

    if (WSAStartup(MAKEWORD(2, 2), &wsa) != 0) {
        printf("Error: WSAStartup failed\n");
        return 1;
    }

    master_socket = socket(AF_INET, SOCK_STREAM, 0);
    if (master_socket == INVALID_SOCKET) {
        printf("Error: Could not create socket\n");
        return 1;
    }

    server.sin_family = AF_INET;
    server.sin_addr.s_addr = INADDR_ANY;
    server.sin_port = htons(PORT);

    if (bind(master_socket, (struct sockaddr *)&server, sizeof(server)) == SOCKET_ERROR) {
        printf("Error: Bind failed\n");
        return 1;
    }

    listen(master_socket, 5);

    while (1) {
        FD_ZERO(&readfds);
        FD_SET(master_socket, &readfds);

        for (int i = 0; i < MAX_CLIENTS; i++) {
            if (clients[i].socket > 0) FD_SET(clients[i].socket, &readfds);
        }

        if (select(0, &readfds, NULL, NULL, NULL) == SOCKET_ERROR) {
            printf("Error: Select failed\n");
            break;
        }

        if (FD_ISSET(master_socket, &readfds)) {
            new_socket = accept(master_socket, NULL, NULL);
            for (int i = 0; i < MAX_CLIENTS; i++) {
                if (clients[i].socket == 0) {
                    clients[i].socket = new_socket;
                    clients[i].logged_in = 0;
                    memset(clients[i].cmd_buffer, 0, BUFFER_SIZE);
                    char *msg = "User Pass: ";
                    send(new_socket, msg, strlen(msg), 0);
                    break;
                }
            }
        }

        for (int i = 0; i < MAX_CLIENTS; i++) {
            if (clients[i].socket > 0 && FD_ISSET(clients[i].socket, &readfds)) {
                char temp[BUFFER_SIZE] = {0};
                int valread = recv(clients[i].socket, temp, sizeof(temp) - 1, 0);

                if (valread <= 0) {
                    closesocket(clients[i].socket);
                    clients[i].socket = 0;
                } else {
                    strncat(clients[i].cmd_buffer, temp, valread);
                    char *pos = strchr(clients[i].cmd_buffer, '\n');
                    if (pos != NULL) {
                        *pos = '\0';
                        char *r_pos = strchr(clients[i].cmd_buffer, '\r');
                        if (r_pos) *r_pos = '\0';

                        if (clients[i].logged_in == 0) {
                            char user[100], pass[100];
                            if (sscanf(clients[i].cmd_buffer, "%s %s", user, pass) == 2) {
                                if (check_login(user, pass)) {
                                    clients[i].logged_in = 1;
                                    char *ok = "Login OK. Command: \n";
                                    send(clients[i].socket, ok, strlen(ok), 0);
                                } else {
                                    char *fail = "Failed. User Pass: ";
                                    send(clients[i].socket, fail, strlen(fail), 0);
                                }
                            }
                        } else {
                            char final_cmd[BUFFER_SIZE + 20];
                            sprintf(final_cmd, "%s > out.txt 2>&1", clients[i].cmd_buffer);
                            system(final_cmd);
                            send_command_result(clients[i].socket);
                        }
                        memset(clients[i].cmd_buffer, 0, BUFFER_SIZE);
                    }
                }
            }
        }
    }
    WSACleanup();
    return 0;
}
