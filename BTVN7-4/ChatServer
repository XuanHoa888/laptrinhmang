#include <stdio.h>
#include <winsock2.h>
#include <time.h>
#include <string.h>

#pragma comment(lib, "ws2_32.lib")

#define PORT 9000
#define MAX_CLIENTS 100
#define BUFFER_SIZE 1024

typedef struct {
    SOCKET socket;
    char name[50];
    int registered;
    char cmd_buffer[BUFFER_SIZE];
} Client;

int main() {
    WSADATA wsa;
    SOCKET master_socket, new_socket;
    struct sockaddr_in server, address;
    int addrlen = sizeof(address);
    fd_set readfds;
    Client clients[MAX_CLIENTS] = {0};

    if (WSAStartup(MAKEWORD(2, 2), &wsa) != 0) {
        return 1;
    }

    master_socket = socket(AF_INET, SOCK_STREAM, 0);
    server.sin_family = AF_INET;
    server.sin_addr.s_addr = INADDR_ANY;
    server.sin_port = htons(PORT);

    bind(master_socket, (struct sockaddr *)&server, sizeof(server));
    listen(master_socket, 5);

    printf("Server dang chay tren port %d...\n", PORT);

    while (1) {
        FD_ZERO(&readfds);
        FD_SET(master_socket, &readfds);

        for (int i = 0; i < MAX_CLIENTS; i++) {
            if (clients[i].socket > 0) FD_SET(clients[i].socket, &readfds);
        }

        // Cho doi tin hieu tu socket
        select(0, &readfds, NULL, NULL, NULL);

        // CO KET NOI MOI
        if (FD_ISSET(master_socket, &readfds)) {
            new_socket = accept(master_socket, (struct sockaddr *)&address, &addrlen);
            printf("Co client moi ket noi! Socket: %d\n", new_socket);
            
            for (int i = 0; i < MAX_CLIENTS; i++) {
                if (clients[i].socket == 0) {
                    clients[i].socket = new_socket;
                    clients[i].registered = 0;
                    memset(clients[i].cmd_buffer, 0, BUFFER_SIZE);
                    break;
                }
            }
        }

        for (int i = 0; i < MAX_CLIENTS; i++) {
            if (clients[i].socket > 0 && FD_ISSET(clients[i].socket, &readfds)) {
                char temp[BUFFER_SIZE] = {0};
                int valread = recv(clients[i].socket, temp, sizeof(temp) - 1, 0);

                if (valread <= 0) {
                    printf("Client %s da thoat.\n", clients[i].name);
                    closesocket(clients[i].socket);
                    clients[i].socket = 0;
                } else {
                    strncat(clients[i].cmd_buffer, temp, valread);

                    char *pos = strchr(clients[i].cmd_buffer, '\n');
                    if (pos != NULL) {
                        *pos = '\0';
                        
                        char *r_pos = strchr(clients[i].cmd_buffer, '\r');
                        if (r_pos) *r_pos = '\0';

                        if (!clients[i].registered) {
                            char id_temp[50], name_temp[50];
                            // Kiem tra cu phap: client_id: client_name
                            if (sscanf(clients[i].cmd_buffer, "client_id: %s", name_temp) == 1) {
                                strcpy(clients[i].name, name_temp);
                                clients[i].registered = 1;
                                send(clients[i].socket, "DANG KY THANH CONG!\n", 20, 0);
                                printf("Client socket %d da dang ky ten: %s\n", clients[i].socket, name_temp);
                            } else {
                                send(clients[i].socket, "SAI CU PHAP! Gui lai: client_id: name\n", 38, 0);
                            }
                        } 
                        else {
                            time_t rawtime;
                            struct tm *info;
                            char time_str[30], send_msg[BUFFER_SIZE + 100];
                            
                            time(&rawtime);
                            info = localtime(&rawtime);
                            strftime(time_str, sizeof(time_str), "%Y/%m/%d %I:%M:%S%p", info);

                            sprintf(send_msg, "%s %s: %s\n", time_str, clients[i].name, clients[i].cmd_buffer);

                            for (int j = 0; j < MAX_CLIENTS; j++) {
                                // Gui cho moi nguoi tru chinh minh va nguoi chua dang ky
                                if (clients[j].socket > 0 && clients[j].socket != clients[i].socket && clients[j].registered) {
                                    send(clients[j].socket, send_msg, strlen(send_msg), 0);
                                }
                            }
                        }
                        memset(clients[i].cmd_buffer, 0, BUFFER_SIZE);
                    }
                }
            }
        }
    }

    WSACleanup();
    return 0;
}
